{{/* Go template — rendered by 'controlai deploy' or manually */}}
version: "3.8"

services:
  mqtt-bridge:
    image: ghcr.io/8bitnyan/controlai-web/mqtt-bridge:latest
    restart: unless-stopped
    ports:
      - "8080:8080"
    environment:
      DATABASE_URL: "{{.DatabaseURL}}"
      STREAM_JWT_SECRET: "{{.StreamJWTSecret}}"
      UPSTASH_REDIS_URL: "{{.UpstashRedisURL}}"
      UPSTASH_REDIS_TOKEN: "{{.UpstashRedisToken}}"
      CORS_ORIGIN: "https://{{.VercelURL}}"
      PORT: "8080"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
    networks:
      - controlai

networks:
  controlai:
    external: true
