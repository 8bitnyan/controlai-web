# ─── Required ─────────────────────────────────────────────────────────────────

# Neon Postgres connection string
# Get from https://neon.tech → your project → Connection Details
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/controlai-web?sslmode=require

# better-auth: 32-byte random secret for session signing
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-32-byte-random-secret

# better-auth: public base URL of this app
BETTER_AUTH_URL=http://localhost:3000

# AES-256-GCM key for encrypting daemon bearer tokens (must be exactly 64 hex chars = 32 bytes)
# Generate with: node -e "require('crypto').randomBytes(32).toString('hex') |> console.log"
INSTANCE_TOKEN_KEY=replace-with-64-char-hex-string

# Shared default-daemon HTTPS base URL (set per-environment)
DEFAULT_DAEMON_BASE_URL=https://default.daemons.controlai.io

# Bearer token for the shared default daemon (encrypted at rest in the DB; required for org bootstrap)
DEFAULT_DAEMON_BEARER_TOKEN=

# Secret header value for the Vercel Cron endpoint (prevents public invocation)
# Generate with: openssl rand -hex 20
CRON_SECRET=replace-with-random-cron-secret

# ─── Optional ─────────────────────────────────────────────────────────────────

# Resend API key for org invitation emails (omit to use stub/log-only mode)
# RESEND_API_KEY=re_xxxxx

# ─── Phase 2 (mqtt-bridge SSE — not required for this change) ─────────────────

# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx
# STREAM_SERVICE_URL=http://localhost:4002 # DEV ONLY
# STREAM_JWT_SECRET=replace-with-hs256-shared-secret

# ─── Gateway Simulator ────────────────────────────────────────────────────────

# Internal URL where the web API proxies gateway commands to the simulator
# Default: http://localhost:4001
# SIMULATOR_INTERNAL_URL=http://localhost:4001

# Public URL (browser-reachable) for the simulator SSE streams
# Default: same as SIMULATOR_INTERNAL_URL in dev
# SIMULATOR_PUBLIC_URL=http://localhost:4001

# Shared secret used by the web API to authenticate calls to the simulator
# Generate with: openssl rand -hex 32
# SIMULATOR_API_TOKEN=replace-with-random-secret

# DEV ONLY: set true to ignore MQTT TLS hostname/cert validation in simulator
# (useful when endpoint host and broker cert CN/SAN don't match)
SIM_TLS_INSECURE=false

# Daemon provisioning
DAEMON_BASE_DOMAIN=daemons.controlai.io
NEXT_PUBLIC_DAEMON_BASE_DOMAIN=daemons.controlai.io
INSTANCE_PROVISIONER=mock # supported values: mock | ec2
# Required only when INSTANCE_PROVISIONER=ec2
AWS_REGION=ap-northeast-2
AWS_ACCOUNT_ID=
ECS_CLUSTER_NAME=controlai-daemons
ECS_TASK_FAMILY=controlai-daemon
ECS_TASK_ROLE_ARN=
ECS_EXECUTION_ROLE_ARN=
ECS_SECURITY_GROUP_ID=
ECS_SUBNETS=subnet-,subnet-
CADDY_ADMIN_ENDPOINT=http://caddy.daemons.local:2019
SECRETS_KMS_KEY_ARN=
DAEMON_LOG_GROUP=/aws/ecs/controlai-daemons
# Substitute <account> with your AWS account ID
DAEMON_IMAGE=<account>.dkr.ecr.ap-northeast-2.amazonaws.com/controlai-daemon:stable
