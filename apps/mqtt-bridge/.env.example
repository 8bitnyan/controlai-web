# Required: Postgres connection string (read replica or primary)
DATABASE_URL=postgresql://user:password@host:5432/controlai_web

# Required: Shared HS256 secret for SSE JWT verification (set in both mqtt-bridge and Vercel)
STREAM_JWT_SECRET=change-me-minimum-32-chars-long!!

# Optional: Upstash Redis for message buffering (Redis Streams)
UPSTASH_REDIS_URL=rediss://default@your-upstash-endpoint.upstash.io:6380
UPSTASH_REDIS_TOKEN=your-upstash-token

# Optional: CORS origin for SSE connections
CORS_ORIGIN=https://your-vercel-deployment.vercel.app

# Port to listen on (default: 8080)
PORT=8080
