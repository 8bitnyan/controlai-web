# ─── Gateway Simulator ────────────────────────────────────────────────────────

# Postgres connection string (same DB as the web app)
DATABASE_URL=postgresql://user:password@ep-xxx.us-east-1.aws.neon.tech/controlai-web?sslmode=require

# AES-256-GCM key for decrypting stored PEMs (must match INSTANCE_TOKEN_KEY in web app)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INSTANCE_TOKEN_KEY=replace-with-64-char-hex-string

# HS256 JWT secret for authenticating browser SSE connections (must match STREAM_JWT_SECRET in web app)
STREAM_JWT_SECRET=replace-with-hs256-shared-secret

# Port the simulator HTTP server listens on (default: 4001)
# SIMULATOR_PORT=4001

# Shared secret the web API sends in Authorization header when calling the simulator
# Must match SIMULATOR_API_TOKEN in the web app
# SIMULATOR_API_TOKEN=replace-with-random-secret
